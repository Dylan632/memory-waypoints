# Vercel Blob creates these values automatically after the store is connected.
BLOB_STORE_ID=
BLOB_WEBHOOK_PUBLIC_KEY=

# Generate a scrypt hash with api/_lib/auth.ts; never store the plain password here.
ADMIN_PASSWORD_HASH=

# A random value of at least 32 characters, used to sign sessions.
SESSION_SECRET=

# A separate random value of at least 32 characters. Back it up before changing it.
DRAFT_ENCRYPTION_KEY=
